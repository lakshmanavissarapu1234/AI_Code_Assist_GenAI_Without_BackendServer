{
  "manifest_version": 3,
  "name": "AI Code Assist",
  "version": "0.4",
  "permissions": ["activeTab", "scripting", "sidePanel", "storage"],
  "host_permissions": [
  "https://generativelanguage.googleapis.com/*"
],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Selector Tool"
  }
}